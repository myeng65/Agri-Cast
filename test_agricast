# recommend_crop tests
# ---------------------------------------------------------------------------
class TestRecommendCrop:
    """Tests for the recommend_crop tool."""
    def test_returns_top_3_crops(self):
        """Function must always return exactly 3 crop recommendations."""
        result = json.loads(recommend_crop(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20
        ))
        assert "top_recommendations" in result
        assert len(result["top_recommendations"]) == 3
    def test_recommendations_ranked_descending(self):
        """Crops must be sorted by compatibility_pct descending."""
        result = json.loads(recommend_crop(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20
        ))
        scores = [r["compatibility_pct"] for r in result["top_recommendations"]]
        assert scores == sorted(scores, reverse=True)
    def test_compatibility_pct_in_valid_range(self):
        """All compatibility percentages must be in [0, 100]."""
        result = json.loads(recommend_crop(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20
        ))
        for rec in result["top_recommendations"]:
            assert 0 <= rec["compatibility_pct"] <= 100
    def test_wheat_matches_wheat_ideal_soil(self):
        """Wheat-ideal conditions should return Wheat as top recommendation."""
        result = json.loads(recommend_crop(
            ph=6.5, nitrogen=55, phosphorus=40, potassium=65,
            moisture=42, temperature=18
        ))
        top_crop = result["top_recommendations"][0]["crop"]
        # Wheat or any close match — score should be >= 80
        top_score = result["top_recommendations"][0]["compatibility_pct"]
        assert top_score >= 60  # At least a moderate match
    def test_rice_matches_high_moisture(self):
        """High moisture conditions should favour rice."""
        result = json.loads(recommend_crop(
            ph=6.0, nitrogen=80, phosphorus=40, potassium=55,
            moisture=85, temperature=28
        ))
        top_names = [r["crop"] for r in result["top_recommendations"]]
        assert "Rice" in top_names
    def test_each_recommendation_has_required_fields(self):
        """Each recommendation must have crop, type, compatibility_pct, status, grow_days."""
        result = json.loads(recommend_crop(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20
        ))
        for rec in result["top_recommendations"]:
            for field in ("crop", "type", "compatibility_pct", "status", "grow_days"):
                assert field in rec
