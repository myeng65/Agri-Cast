class TestAssessWeatherRisk:
    """Tests for the assess_weather_risk tool."""
    def test_frost_returns_hazardous(self):
        """Frost condition should produce a very low planting rating."""
        result = json.loads(assess_weather_risk(
            region="temperate", crop_name="Wheat",
            temp_min=-3, temp_max=5, wind_speed=10, condition="Frost"
        ))
        assert result["planting_rating"] < 40
        assert "Hazardous" in result["label"]
    def test_heavy_rain_reduces_rating(self):
        """Heavy Rain should reduce the planting rating significantly."""
        result_rain = json.loads(assess_weather_risk(
            region="tropical", crop_name="Maize (Corn)",
            temp_min=18, temp_max=25, wind_speed=10, condition="Heavy Rain"
        ))
        result_sunny = json.loads(assess_weather_risk(
            region="tropical", crop_name="Maize (Corn)",
            temp_min=18, temp_max=25, wind_speed=10, condition="Sunny"
        ))
        assert result_rain["planting_rating"] < result_sunny["planting_rating"]
    def test_light_rain_boosts_rating(self):
        """Light Rain should boost the planting rating."""
        result_rain = json.loads(assess_weather_risk(
            region="temperate", crop_name="Wheat",
            temp_min=12, temp_max=20, wind_speed=8, condition="Light Rain"
        ))
        result_sunny = json.loads(assess_weather_risk(
            region="temperate", crop_name="Wheat",
            temp_min=12, temp_max=20, wind_speed=8, condition="Sunny"
        ))
        assert result_rain["planting_rating"] >= result_sunny["planting_rating"]
    def test_high_wind_reduces_rating(self):
        """Wind speed > 25 km/h should reduce the rating."""
        result_windy = json.loads(assess_weather_risk(
            region="temperate", crop_name="Wheat",
            temp_min=12, temp_max=20, wind_speed=35, condition="Sunny"
        ))
        result_calm = json.loads(assess_weather_risk(
            region="temperate", crop_name="Wheat",
            temp_min=12, temp_max=20, wind_speed=8, condition="Sunny"
        ))
        assert result_windy["planting_rating"] < result_calm["planting_rating"]
    def test_unknown_crop_returns_error(self):
        """Unknown crop name should return an error field."""
        result = json.loads(assess_weather_risk(
            region="temperate", crop_name="Dragonberry",
            temp_min=10, temp_max=20, wind_speed=10, condition="Sunny"
        ))
        assert "error" in result
    def test_rating_bounded_0_to_100(self):
        """Rating must always be in [0, 100]."""
        result = json.loads(assess_weather_risk(
            region="temperate", crop_name="Tomato",
            temp_min=-10, temp_max=45, wind_speed=60, condition="Thunderstorm"
        ))
        assert 0 <= result["planting_rating"] <= 100
    def test_result_has_required_fields(self):
        """Result must have planting_rating, label, and risk_factors."""
        result = json.loads(assess_weather_risk(
            region="arid", crop_name="Wheat",
            temp_min=15, temp_max=28, wind_speed=12, condition="Sunny"
        ))
        for key in ("planting_rating", "label", "risk_factors", "crop", "region"):
            assert key in result
