# ---------------------------------------------------------------------------
# analyze_soil tests
# ---------------------------------------------------------------------------
class TestAnalyzeSoil:
    """Tests for the analyze_soil tool."""
    def test_optimal_soil_returns_high_score(self):
        """Optimal loam soil with ideal NPK/pH should score >= 85."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20, soil_type="loam"
        ))
        assert result["health_score"] >= 85
        assert result["grade"] == "Excellent"
    def test_acidic_ph_lowers_score(self):
        """Severely acidic pH should trigger a critical warning and reduce score."""
        result = json.loads(analyze_soil(
            ph=4.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20, soil_type="loam"
        ))
        assert result["health_score"] < 80
        assert any("acidic" in insight.lower() or "lime" in insight.lower()
                   for insight in result["insights"])
    def test_alkaline_ph_lowers_score(self):
        """Alkaline pH > 8.5 should trigger a critical warning."""
        result = json.loads(analyze_soil(
            ph=9.0, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20, soil_type="loam"
        ))
        assert result["health_score"] < 80
        assert any("alkaline" in insight.lower() for insight in result["insights"])
    def test_low_nitrogen_triggers_warning(self):
        """N < 40 mg/kg should produce a low-nitrogen insight."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=20, phosphorus=50, potassium=100,
            moisture=55, temperature=20
        ))
        assert result["health_score"] < 90
        assert any("LOW N" in insight or "nitrogen" in insight.lower()
                   for insight in result["insights"])
    def test_low_phosphorus_triggers_warning(self):
        """P < 30 mg/kg should produce a low-phosphorus insight."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=80, phosphorus=15, potassium=100,
            moisture=55, temperature=20
        ))
        assert any("LOW P" in insight for insight in result["insights"])
    def test_low_potassium_triggers_warning(self):
        """K < 60 mg/kg should produce a low-potassium insight."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=30,
            moisture=55, temperature=20
        ))
        assert any("LOW K" in insight for insight in result["insights"])
    def test_dry_soil_triggers_irrigation_alert(self):
        """Moisture < 35% should trigger a dry alert."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=15, temperature=20
        ))
        assert any("DRY" in insight.upper() for insight in result["insights"])
    def test_waterlogged_soil_triggers_warning(self):
        """Moisture > 80% should trigger a waterlogging warning."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=90, temperature=20
        ))
        assert any("WATERLOGGED" in insight.upper() for insight in result["insights"])
    def test_sandy_soil_type_note_included(self):
        """Sandy soil_type should include a texture-specific insight."""
        result = json.loads(analyze_soil(
            ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
            moisture=55, temperature=20, soil_type="sand"
        ))
        assert any("sandy" in insight.lower() or "leach" in insight.lower()
                   for insight in result["insights"])
    def test_score_bounded_between_0_and_100(self):
        """Score must always be in [0, 100] even under worst conditions."""
        result = json.loads(analyze_soil(
            ph=3.0, nitrogen=5, phosphorus=5, potassium=5,
            moisture=0, temperature=0, soil_type="sand"
        ))
        assert 0 <= result["health_score"] <= 100
    def test_return_type_is_valid_json(self):
        """Result must be valid JSON with required fields."""
        raw = analyze_soil(ph=6.5, nitrogen=80, phosphorus=50, potassium=100,
                           moisture=55, temperature=20)
        result = json.loads(raw)
        for key in ("health_score", "grade", "insights", "ph", "nitrogen"):
            assert key in result
