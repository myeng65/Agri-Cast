class TestGetIrrigationPlan:
    """Tests for the get_irrigation_plan tool."""
    def test_critical_dry_triggers_urgent_irrigation(self):
        """Moisture critically below minimum should return CRITICAL urgency."""
        result = json.loads(get_irrigation_plan(
            field_name="East Acre", moisture_pct=15.0,
            temperature=22.0, crop_name="Wheat"
        ))
        assert result["irrigation_urgency"] == "CRITICAL"
    def test_waterlogged_triggers_high_urgency(self):
        """Severely waterlogged field should return HIGH urgency to suspend irrigation."""
        result = json.loads(get_irrigation_plan(
            field_name="South Valley", moisture_pct=95.0,
            temperature=20.0, crop_name="Wheat"
        ))
        assert result["irrigation_urgency"] in ("HIGH", "MODERATE")
        assert any("suspend" in a.lower() or "waterlog" in a.lower() or "drainage" in a.lower()
                   for a in result["recommended_actions"])
    def test_optimal_moisture_returns_none_urgency(self):
        """Moisture within optimal range should return None urgency."""
        result = json.loads(get_irrigation_plan(
            field_name="West Ridge", moisture_pct=45.0,
            temperature=20.0, crop_name="Wheat"
        ))
        assert result["irrigation_urgency"] == "None"
    def test_high_temperature_triggers_timing_advice(self):
        """Temperature > 35°C should add a timing recommendation."""
        result = json.loads(get_irrigation_plan(
            field_name="East Acre", moisture_pct=40.0,
            temperature=38.0, crop_name="Maize (Corn)"
        ))
        assert any("morning" in a.lower() or "evaporation" in a.lower()
                   for a in result["recommended_actions"])
    def test_low_temperature_advises_against_irrigation(self):
        """Temperature < 10°C should warn against irrigation to avoid frost damage."""
        result = json.loads(get_irrigation_plan(
            field_name="East Acre", moisture_pct=40.0,
            temperature=5.0, crop_name="Wheat"
        ))
        assert any("frost" in a.lower() or "low" in a.lower()
                   for a in result["recommended_actions"])
    def test_result_has_required_fields(self):
        """Result must include field, crop, moisture, urgency, and actions."""
        result = json.loads(get_irrigation_plan(
            field_name="South Valley", moisture_pct=60.0,
            temperature=22.0, crop_name="Rice"
        ))
        for key in ("field", "crop", "current_moisture", "irrigation_urgency",
                    "recommended_actions", "optimal_moisture_range"):
            assert key in result
    def test_unknown_crop_uses_default_thresholds(self):
        """Unknown crop should still return a valid plan with default thresholds."""
        result = json.loads(get_irrigation_plan(
            field_name="North Field", moisture_pct=50.0,
            temperature=20.0, crop_name="ExoticUnknownCrop"
        ))
        assert "irrigation_urgency" in result
        assert len(result["recommended_actions"]) > 0
